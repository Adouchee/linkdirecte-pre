{
  "name": "linkdirecte",
  "version": "0.0.0",
  "description": "Your first-rate SDK for working with EcoleDirecte data.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Scolup/Linkdirecte"
  },
  "bugs": {
    "url": "https://github.com/Scolup/Linkdirecte/issues"
  },
  "homepage": "https://github.com/Scolup/Linkdirecte#readme",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=18"
  },
  "keywords": ["ecoledirecte", "sdk", "api", "school"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "browser": "./dist/index.js",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "tsc",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "precommit": "npm run format && npm run lint && npm run test",
    "test": "bun test"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "msrcrypto": "^1.5.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.1",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
