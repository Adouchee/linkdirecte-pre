{
  "name": "linkdirecte",
  "version": "0.0.0",
  "description": "Your first-rate SDK for working with EcoleDirecte data.",
  "license": "AGPL-3.0-or-later",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "tsc --noEmit",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "precommit": "npm run format && npm run lint",
    "test": "bun test"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.1",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
