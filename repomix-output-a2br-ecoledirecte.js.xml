export function cleanMessages(
	mailboxRes: mailboxResSuccess,
	student: Student
): Message[] {
	const { received, sent } = mailboxRes.data.messages;
	const all = [...received, ...sent];
	const messages: Message[] = all
		.map(v => new Message(v, student))
		.sort((a, b) => a.id - b.id);

	return messages;
}
