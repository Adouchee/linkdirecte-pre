		// eslint-disable-next-line quotes
		'" Not A;Brand";v="99", "Chromium";v="90", "Google Chrome";v="90"',
	accept: "application/json, text/plain, */*",
	"sec-ch-ua-mobile": "?0",
	"user-agent": USER_AGENT,
